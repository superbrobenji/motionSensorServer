# Serial port configuration
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=115200

# Dual-master failover (optional)
DUAL_MASTER_ENABLED=false
SERIAL_PORT_SECONDARY=

# API configuration
API_PORT=8080
API_KEY=change-me-before-deploy

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=1

# Data persistence paths (relative to working directory)
AUTH_REGISTRY_PATH=data/nodeauth.json
NODE_REGISTRY_PATH=data/nodes.json
ZONE_REGISTRY_PATH=data/zones.json

# Logging: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
