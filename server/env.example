# Planetopia Mesh Server Configuration
# Copy this file to .env and modify as needed

# Serial port configuration
# Examples: /dev/ttyUSB0, /dev/ttyACM0, /dev/serial/by-id/...
# For Proxmox containers: the device is mapped in docker-compose.yml, keep this as /dev/ttyUSB0
SERIAL_PORT=/dev/ttyUSB0

# Serial communication settings
BAUD_RATE=115200

# HTTP API port
API_PORT=8080

# Uncomment and modify these if you need to override Kafka settings
# KAFKA_BROKER=kafka:9092

# Kafka consumer group ID
KAFKA_GROUP_ID=1

# Path to node registry persistence file
NODE_REGISTRY_PATH=data/nodeauth.json

# Log level: DEBUG, INFO, WARN, ERROR (placeholder — will be wired to slog in a future task)
LOG_LEVEL=INFO

# HTTP API authentication key (required in production)
# Generate with: openssl rand -hex 32
# Leave empty to run without authentication (development only)
API_KEY=

# Dashboard API URL (for dashboard container)
VITE_API_URL=http://localhost:8080

# Dashboard API key (must match API_KEY above)
VITE_API_KEY=

# Comma-separated allowed CORS origins for the API server
ALLOWED_ORIGINS=http://localhost:5173

# For Docker Compose with USB serial device:
# 1. Uncomment the devices section in docker-compose.yml
# 2. Ensure your user has permission to access the device:
#    sudo usermod -a -G dialout $USER
#    sudo chmod 666 /dev/ttyUSB0
